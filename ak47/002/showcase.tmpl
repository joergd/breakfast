body {
  margin:0px;
  padding:0px;
  padding-bottom:25px;
  background: #EDAA08 url(/ak47/002/graphics/back.gif) bottom left fixed repeat-x;
  font: 11px Verdana, Arial, Helvetica, sans-serif;
  text-align:center;
  line-height:1.6em;
  border-top: 10px solid #101427;
}

img {
  padding:0px;
  margin:0px;
  border:0px;
}

a {
  color:#572605;
  text-decoration:none;
}

a:hover {
  color: #F7EDEE;
  background: #572605;
}


h1 {
  display:inline;
  padding:0px;
  margin:0px;
  font-size: 11px;
  font-weight:bold;
}

#container {
  position:relative;
  width:752px;
  height:700px;
  margin:0px;
  margin-left:auto;
  margin-right:auto;
  margin-top:20px;
  text-align:left;
  background-color: #F7EDEE;
  border-top: 20px solid #A77806;
  border-bottom: 20px solid #976C05;
  border-left: 1px solid #A77806;
  border-right: 1px solid #A77806;
}

#slideshow {
  position:absolute;
  top:0px;
  left:0px;
}

#copyright {
  position:absolute;
  bottom:-40px;
  right: 0px;
  color: #572605;
}


#menu {
  position:absolute;
  top:701px;
  left: 6px;
  color: white;
  font-weight:700;
}

#details {
  position:absolute;
  top:-18px;
  left: 8px;
  color: white;
  font-weight:700;
}


#menu a {
  color: white;
  text-decoration:underline;
}

#details a {
  color: white;
  text-decoration:underline;
}

#menu a:hover {
  color: #976C05;
  background: white;
}

#details a:hover {
  color: #A77806;
  background: white;
}